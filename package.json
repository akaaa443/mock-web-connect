{
  "name": "mock-web-connect-server",
  "version": "1.0.0",
  "description": "Mock WebSocket server for AIS Web Connect ID card reader",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "gen-cert": "openssl req -x509 -newkey rsa:2048 -keyout certs/key.pem -out certs/cert.pem -days 365 -nodes -subj '/CN=localhost'"
  },
  "dependencies": {
    "@pokusew/pcsclite": "^0.6.0",
    "ws": "^8.18.0"
  }
}
